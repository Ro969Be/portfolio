{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "jsx": "preserve",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "types": [
            "vite/client",
            "@cloudflare/workers-types"
        ]
    },
    "include": [
        "src",
        "functions"
    ]
}